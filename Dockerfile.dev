FROM alpine:3.19

RUN apk update && apk add --no-cache \
    bash \
    tmux \
    ranger \
    micro \
    vim \
    git \
    curl \
    less \
    ncurses \
    ca-certificates \
    sudo

# Usuário dev (com sudo)
RUN addgroup -g 1000 dev && \
    adduser -D -u 1000 -G dev dev && \
    echo "dev ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers

USER dev
WORKDIR /workspace

COPY tmux.conf /home/dev/.tmux.conf
COPY config /home/dev/.config

ENV TERM=xterm-256color
ENV SHELL=/bin/bash

CMD ["bash"]

