# =============================================================================
# TUI Container - DEV Mode
# =============================================================================
# Base: Alpine Linux 3.19
# User: dev (with sudo)
# Purpose: Development environment with full shell access
# =============================================================================

FROM alpine:3.19

# -----------------------------------------------------------------------------
# System packages
# -----------------------------------------------------------------------------
RUN apk update && apk add --no-cache \
    bash \
    tmux \
    ranger \
    micro \
    vim \
    git \
    curl \
    less \
    ncurses \
    ca-certificates \
    sudo

# -----------------------------------------------------------------------------
# User creation (dev with sudo)
# -----------------------------------------------------------------------------
RUN addgroup -g 1000 dev && \
    adduser -D -u 1000 -G dev dev && \
    echo "dev ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers

# -----------------------------------------------------------------------------
# Working directory
# -----------------------------------------------------------------------------
USER dev
WORKDIR /workspace

# -----------------------------------------------------------------------------
# Copy configuration files
# -----------------------------------------------------------------------------
COPY --chown=dev:dev tmux.conf /home/dev/.tmux.conf
COPY --chown=dev:dev config /home/dev/.config

# -----------------------------------------------------------------------------
# Environment variables
# -----------------------------------------------------------------------------
ENV TERM=xterm-256color
ENV SHELL=/bin/bash

# -----------------------------------------------------------------------------
# Default command
# -----------------------------------------------------------------------------
CMD ["bash"]