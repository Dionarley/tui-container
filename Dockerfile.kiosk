# =============================================================================
# TUI Container - KIOSK Mode
# =============================================================================
# Base: Alpine Linux 3.19
# User: tui (no sudo)
# Purpose: Immutable appliance-style environment
# =============================================================================

FROM alpine:3.19

# -----------------------------------------------------------------------------
# System packages
# -----------------------------------------------------------------------------
RUN apk update && apk add --no-cache \
    bash \
    tmux \
    ranger \
    micro \
    git \
    curl \
    less \
    ncurses \
    ca-certificates

# -----------------------------------------------------------------------------
# User creation (tui without sudo)
# -----------------------------------------------------------------------------
RUN addgroup -g 1000 tui && \
    adduser -D -u 1000 -G tui tui

# -----------------------------------------------------------------------------
# Working directory
# -----------------------------------------------------------------------------
USER tui
WORKDIR /workspace

# -----------------------------------------------------------------------------
# Copy configuration files
# -----------------------------------------------------------------------------
COPY --chown=tui:tui tmux.conf /home/tui/.tmux.conf
COPY --chown=tui:tui tmux-kiosk.conf /home/tui/.tmux-kiosk.conf
COPY --chown=tui:tui config /home/tui/.config

# -----------------------------------------------------------------------------
# Environment variables
# -----------------------------------------------------------------------------
ENV TERM=xterm-256color
ENV SHELL=/bin/bash

# -----------------------------------------------------------------------------
# Default command (tmux in kiosk mode)
# -----------------------------------------------------------------------------
CMD ["tmux", "-f", "/home/tui/.tmux-kiosk.conf"]