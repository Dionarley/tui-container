# =============================================================================
# TUI Container - .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Persistência local
# -----------------------------------------------------------------------------
workspace/*
!workspace/.gitkeep

# -----------------------------------------------------------------------------
# Editor configs
# -----------------------------------------------------------------------------
config/micro/backups/
config/micro/buffers/
config/micro/history

# -----------------------------------------------------------------------------
# Temporary files
# -----------------------------------------------------------------------------
*.swp
*.tmp
*.swo
*~

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
*.log
.docker/

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Screenshots (auto-generated)
# -----------------------------------------------------------------------------
screenshots/
